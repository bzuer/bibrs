@Article{roniger2017,
  author        = {Roniger, Luis},
  journal       = {The Wiley-Blackwell Encyclopedia of Social Theory},
  title         = {!'scp¿E!'/scp¿isenstadt,!'scp¿S!'/scp¿hmuel!'scp¿N!'/scp¿oah},
  year          = {2017},
  pages         = {1–4},
  abstract      = {A major figure of macro-sociology, Shmuel Noah Eisenstadt developed a comparative-historical perspective that brought together the comparative study of institutions, Martin Buber's lead on human creativity, and a Weberian interest in world religions and civilizations. His approach intertwined structural differentiation within a cultural-interpretative approach to social dynamics in historical and modern societies. Among his contributions are studies stressing the role of agency, structure, and culture in processes of change; a critical assessment of modernization and revolutions; institutional and civilizational analyses, among them of Japan and Jewish civilization; and the perspective of ``multiple modernities.''},
  bdsk-url-1    = {https://doi.org/10.1002/9781118430873.est0104},
  date-modified = {2026-03-18 00:34:05 -0300},
  doi           = {10.1002/9781118430873.est0104},
  keywords      = {Philosophy,Epistemology,Sociology,Law,Political science,Theology,Social science,Modernization theory,Perspective (graphical),Civilization,Anthropology,Judaism,Agency (philosophy),Structure and agency,Creativity},
  language      = {da},
}

@Article{benrafael2018,
  author        = {Ben-Rafael, Eliezer},
  journal       = {The Blackwell Encyclopedia of Sociology},
  title         = {!'scp¿E!'/scp¿isenstadt,!'scp¿S.N.!'/scp¿(1923–2010)},
  year          = {2018},
  pages         = {1–3},
  abstract      = {Abstract S.N. Eisenstadt (born in Warsaw on September 10, 1923; died in Jerusalem on September 2, 2010) was a prominent sociologist who left an impressive legacy. Combining theory with empirical research, he studied societies and civilizations, investigating both the making and the unmaking of social orders, and emphasizing the versatility of societal developments. He explored patterns of entrepreneurship, politics, cultural premises, social conflicts, and tensions, and his elaboration of the multiple-modernities concept views modernity as a plurality of cultural and political programs. Eisenstadt rejected both the ``end of history'' and the ``clash of civilizations'' perspectives. He saw in the axial age the formation of crucial ontological conceptions which pulled human agency to modernity.},
  bdsk-url-1    = {https://doi.org/10.1002/9781405165518.wbeos1173},
  date-modified = {2026-03-18 00:34:08 -0300},
  doi           = {10.1002/9781405165518.wbeos1173},
  keywords      = {Philosophy,Epistemology,Sociology,Law,Political science,Politics,Social science,Gender studies,Modernity,Anthropology,Dialectic,Agency (philosophy),Structure and agency},
  language      = {da},
}

