@article{barbalet2000,
  author = {Barbalet, J. M.},
  journal = {European Journal of Sociology},
  title = {Beruf, Rationality and Emotion in Max Weber's Sociology},
  year = {2000},
  issn = {0003-9756, 1474-0583},
  number = {2},
  pages = {329--351},
  volume = {41},
  abstract = {The concept of Beruf , variously translated as `calling' or `vocation', refers to the pracdce of systematic self-control in pursuing constant goals or purposes, which Weber, in The Protestant Etbic and the Spirit of Capitalism (1905), found in both Calvinist religious practice and capitalistic entrepreneurship and labour. But the term is not confined to these applications; it is also central in Science as a Vocation (1917) and Politics as a Vocation (1919). The general significance of the idea of Berufis that it accounts for the mechanisms required to realize in action the quality of rationality, another of Weber's characteristic terms. The connection between rational activity and calling is constant in Weber's discussion. In his early statement of the argument, however, practices of Beruf achieve rationality through the suppression of emotion. In his later discussion, Beruf is achieved through and expresses passion and emotions. , Le terme Beruf , traduit par \guillemotleft{} appel\guillemotright{} ou \guillemotleft{} vocation \guillemotright{}, renvoie a une pratique de severe controle de soi dans la poursuite de ses objectifs que Max Weber a trouve a la fois dans l'exercice de la religion calviniste et dans l'esprit d'entreprise du capitalisme, comme dans son travail [ E.P. 1905]. Le terme est egalement central dans les deux conferences de 1917 et 1919 ( Le savant et le politique ). Beruf designe alors les mecanismes requis pour mettre en œuvre le rationalite, autre concept cher a Weber. Le lien entre activite rationelle et vocation est constant, cependant il y a un grand changement. Dans les textes de 1905, Beruf conduit a la rationalite par la suppression de l'emotion alors que dans les textes plus tardifs Beruf s'appuie sur passion et emotions. , Der Begriff \guillemotright{}Beruf\guillemotleft{}, ubersetzt mit \guillemotright{}calling\guillemotleft{} oder \guillemotright{}vocation\guillemotleft{}, verweist auf die systematische Selbstbeherrschung bei der Verfolgung von Zielen, die Weber in \guillemotright{}Die protestantische Ethik und der Geist des Kaptialismus\guillemotleft{} (1905) sowohl in der calvinistischen Rellgionsausubung als auch dem kapitalistischen Unternehmertum und Arbeit nachweist. Daruber hinaus ist dieser Begriff aber auch in \guillemotright{}Wissenschaft als Beruf\guillemotleft{} (1917) und \guillemotright{}Politik als Beruf\guillemotleft{} (1919) prasent. \guillemotright{}Beruf\guillemotleft{} deutet hier auf jene Mechanismen hin, die die Rationalitat zum Ausdruck bringen, eine andere wichtige Begriffsgattung Webers. Die Verbindung zwischen rationalem Handeln und Berufung ist permanent, in seiner fruhen Argumentationsweise bedeutet \guillemotright{}Beruf\guillemotleft{} jedoch Verzicht auf Gefuhle. Spater dann wird Beruf Ausdruck von Leidenschaft und Gefuhlen.},
  doi = {10.1017/s0003975600007062},
  keywords = {Philosophy, Epistemology, Psychology, Social psychology, Sociology, Law, Political science, Politics, Rationality, Capitalism, Protestantism, Religious studies, Social science, Action (physics), Passion, Argument (complex analysis), Dialectic},
  language = {english}
}

