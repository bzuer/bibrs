@Article{akarsu2025,
  author        = {Akarsu, Hayal},
  journal       = {American Anthropologist},
  title         = {``We're Tired of This Weber Guy!''–Force Experts, Police Reforms, and the Violence of Standardization},
  year          = {2025},
  issn          = {0002-7294, 1548-1433},
  number        = {1},
  pages         = {5–19},
  volume        = {127},
  abstract      = {Abstract Since the mid-2000s, the use-of-force continuum–a global standard for providing law enforcement with guidelines on the proportionate use of force–has been central in Turkish police training and reporting practices. Liberal police accountability tools, like the use-of-force continuum, rely on standardization to prevent police violence. Yet these techniques still result in maimed bodies and psyches and police impunity. Rather than taking the standardization of police force simply as a failed project, a sham, or a mere techno-fix, I examine how powerful actors like police align with such standards and how they start thinking and acting through them while repurposing them. Drawing on 18 months of fieldwork between 2015 and 2017 among the Turkish National Police, I show how the transnational standardization of police force has in fact enabled police in Turkey to redefine and ultimately reclaim the violence they are professionalized in as what I call ``force experts.'' Force defies standardization in both theory and practice; however, what sanctions police violence now is not just technical standardization but the expert framing of the democratically reformed police force. This is the violence of standardization, especially in contexts where governments retool reforms to criminalize suspect Others whom they perceive as a ``threat'' to their rule. , Resumen Desde mediados de la década de 2000 el continuo uso de la fuerza –un estándar global para proveer a los cuerpos policiales directrices sobre el uso proporcionado de la fuerza– ha sido central en el entrenamiento y las prácticas de reporte de la policı á turca. Las herramientas liberales de la rendición de cuentas de la policı á, como el continuo uso de la fuerza, depende de la estandarización para prevenir la violencia de la policı á. Sin embargo, estas técnicas aún resultan en cuerpos y psiques desfigurados e impunidad de la policı á. En vez de tomar la estandarización de la fuerza policial simplemente como un proyecto fallido, una farsa, o un mero arreglo tecnológico, examino cómo actores poderosos como la policı á se alinean con tales estándares y cómo empiezan a pensar y a actuar a través de ellos mientras les cambian de propósito. Basada en 18 meses de trabajo de campo entre 2015 y 2017 entre la Policı á Nacional Turca, muestro cómo la estandarización transnacional de la fuerza policial ha en efecto posibilitado a la policı á en Turquı á redefinir y últimamente reivindicar la violencia en que ellos están profesionalizados como lo que llamo ``expertos en fuerza''. La fuerza reta la estandarización en teorı á y práctica; sin embargo, lo que sanciona la violencia policial ahora no es sólo la estandarización técnica sino el marco experto de la fuerza de policı á reformada democráticamente. Esto es la violencia de la estandarización, especialmente en contextos donde los gobiernos reestructuran reformas para criminalizar a Otros sospechosos a quienes ellos perciben como una ``amenaza'' para su norma. [policı á/vigilancia policial, experiencia, violencia, reforma/estandarización, Turquı á]},
  bdsk-url-1    = {https://onlinelibrary.wiley.com/doi/pdfdirect/10.1111/aman.28028},
  bdsk-url-2    = {https://doi.org/10.1111/aman.28028},
  date-modified = {2026-03-18 00:34:09 -0300},
  doi           = {10.1111/aman.28028},
  keywords      = {Psychology,Sociology,Law,Political science,Criminology,Standardization},
  language      = {en},
  publisher     = {wiley},
  urldate       = {2026-03-12},
}

